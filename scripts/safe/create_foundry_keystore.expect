#!/usr/bin/expect -f

# Feed a password file to cast wallet new through its hidden terminal prompts.
# This keeps the resolved password out of process arguments and environment.

if {$argc != 3} {
  puts stderr "Usage: create_foundry_keystore.expect PASSWORD_FILE KEYSTORE_DIR ACCOUNT"
  exit 64
}

set password_file [lindex $argv 0]
set keystore_dir [lindex $argv 1]
set account [lindex $argv 2]

if {[catch {open $password_file r} password_handle]} {
  puts stderr "Error: cannot open password file"
  exit 1
}
fconfigure $password_handle -translation binary -encoding binary
set password [read $password_handle]
close $password_handle

if {[string length $password] == 0 || [regexp {[\r\n]} $password]} {
  set password ""
  puts stderr "Error: password file must contain one non-empty line without a newline"
  exit 1
}

log_user 0
set timeout 30
spawn -noecho cast wallet new -- $keystore_dir $account

set prompt_count 0
expect {
  -re {(?i)(password|secret)[^:\r\n]*:} {
    incr prompt_count
    if {$prompt_count > 2} {
      set password ""
      puts stderr "Error: Foundry requested the keystore password too many times"
      exit 1
    }
    send -- "$password\r"
    exp_continue
  }
  timeout {
    set password ""
    puts stderr "Error: timed out waiting for Foundry keystore creation"
    exit 1
  }
  eof {}
}

if {$prompt_count == 0} {
  set password ""
  puts stderr "Error: Foundry exited without requesting a keystore password"
  exit 1
}

set password ""
set child_status [wait]
exit [lindex $child_status 3]
