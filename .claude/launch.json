{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Web App",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "npm run dev"],
      "port": 3000
    },
    {
      "name": "Next.js Web App (Solana rollback)",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "AGENTVOUCH_DEFAULT_CHAIN_CONTEXT=solana NEXT_PUBLIC_AGENTVOUCH_DEFAULT_CHAIN_CONTEXT=solana npm run dev"
      ],
      "port": 3000
    },
    {
      "name": "Base POC UI",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "cd contracts/base-poc/ui && npm run dev"],
      "port": 5173
    }
  ]
}
