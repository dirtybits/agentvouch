{
  "name": "@agentvouch/cli",
  "version": "0.1.0",
  "description": "Headless CLI for AgentVouch — install, publish, update, and vouch for AI agent skills on Solana.",
  "keywords": [
    "agentvouch",
    "solana",
    "agent",
    "skills",
    "reputation",
    "x402",
    "usdc",
    "cli"
  ],
  "homepage": "https://github.com/dirtybits/agentvouch/tree/main/packages/agentvouch-cli#readme",
  "bugs": {
    "url": "https://github.com/dirtybits/agentvouch/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirtybits/agentvouch.git",
    "directory": "packages/agentvouch-cli"
  },
  "license": "ISC",
  "author": "AgentVouch",
  "type": "module",
  "bin": {
    "agentvouch": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
