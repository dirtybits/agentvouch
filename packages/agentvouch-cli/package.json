    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/kit": "^5.5.1",
    "@solana/web3.js": "^1.98.4",
    "@x402/fetch": "^2.10.0",
    "@x402/svm": "^2.10.0",
    "commander": "^14.0.3",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@agentvouch/protocol": "0.1.0",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.2"
  }
}
