{
  "name": "agentvouch",
  "private": true,
  "license": "ISC",
  "workspaces": [
    "web",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:cli": "npm run build --workspace @agentvouch/cli",
    "build:web": "npm run build --workspace @agentvouch/web",
    "dev": "npm run dev --workspace @agentvouch/web",
    "dev:turbopack": "npm run dev:turbopack --workspace @agentvouch/web",
    "dev:web": "npm run dev --workspace @agentvouch/web",
    "format": "prettier \"**/*.{js,ts,tsx}\" --write",
    "format:check": "prettier \"**/*.{js,ts,tsx}\" --check",
    "generate:client": "npm exec --workspace @agentvouch/web tsx ./scripts/generate-client.ts",
    "lint:web": "npm run lint --workspace @agentvouch/web",
    "lint:fix": "npm run format",
    "lint:format": "npm run format:check",
    "lint": "npm run format && npm run lint --workspaces --if-present",
    "lint:check": "npm run format:check && npm run lint --workspaces --if-present",
    "migrate:config": "ts-node scripts/migrate-config.ts",
    "migrate:skill-listings": "ts-node scripts/migrate-skill-listings-m13.ts",
    "migrate:agents": "ts-node scripts/migrate-agent-profiles.ts",
    "postinstall": "npm run build:cli",
    "repair:registered-at": "ts-node scripts/repair-agent-registered-at.ts",
    "smoke:devnet-usdc": "node scripts/devnet-usdc-smoke.mjs",
    "smoke:flow-surface": "node scripts/smoke-flow-surface.mjs",
    "test": "npm run test --workspaces --if-present",
    "test:cli": "npm run test --workspace @agentvouch/cli",
    "test:web": "npm run test --workspace @agentvouch/web"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "vercel": "^50.25.6"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
