# AgentVouch Base POC — Gas-Free Demo UI (Base Sepolia)
# Copy to .env.local and fill VITE_CDP_RPC_URL. NOTE: all VITE_* vars are exposed to the browser.

# REQUIRED: Coinbase Developer Platform Paymaster & Bundler URL (Base Sepolia).
# Single endpoint serving eth_sendUserOperation + pm_getPaymasterData.
# Its policy must allow this contract + USDC approve (see ../harness/README.md "Paymaster allowlist").
VITE_CDP_RPC_URL=

# Optional read RPC (defaults to https://sepolia.base.org).
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployed contract + token (defaults baked in; override only if you redeployed).
VITE_AGENTVOUCH_ADDRESS=0x6Fd9E7Fd459eE5D7503d9D549e75596A2c4FD854
VITE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Optional: pre-funded throwaway owner keys so demos skip the faucet (local-key mode only).
# If unset, the app generates + persists a key per role in localStorage.
# Only the BUYER smart account needs test USDC; the author needs none (register + paid-list are free).
VITE_AUTHOR_OWNER_PK=
VITE_BUYER_OWNER_PK=
