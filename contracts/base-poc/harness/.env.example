# --- Gas-free UX harness config (Base Sepolia) ---

# Public RPC for reads (a default Base Sepolia endpoint is used if unset).
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ERC-4337 bundler + ERC-7677 paymaster endpoint. For Coinbase Developer Platform
# this is a single Paymaster & Bundler URL (it serves both eth_sendUserOperation
# and pm_getPaymasterData).
#
# The CDP paymaster policy MUST allow the calls this harness makes, or sponsorship
# is rejected. Empty allowlist = sponsor-all (testnet only). To lock it down, add
# AGENTVOUCH_ADDRESS + the USDC token, restricted to these functions (see
# README.md "Paymaster allowlist" for the authoritative list + selectors):
#   AgentVouch: registerAgent, depositAuthorBond, vouch, createSkillListing,
#               purchaseSkill, claimVoucherRevenue, withdrawAuthorProceeds
#   USDC:       approve
CDP_RPC_URL=

# Deployed contract (from `forge script script/Deploy.s.sol`).
AGENTVOUCH_ADDRESS=

# Base Sepolia USDC (Circle testnet). Default below; override if you deployed a mock.
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Persistent smart-account OWNER keys. These sign UserOps; they never send txs and
# never need ETH. Keep them stable so the smart-account addresses (which you fund
# with test USDC) don't change between runs. If unset, the harness generates a set
# and prints them — copy them here, then fund the printed addresses and re-run.
AUTHOR_OWNER_PK=
VOUCHER_OWNER_PK=
BUYER_OWNER_PK=
